# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Supabase — direct PostgreSQL connection (find in Supabase dashboard → Settings → Database)
# Format: postgresql://postgres:[DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Resend (email magic links)
RESEND_API_KEY=re_...

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# App
PORT=8000
BASE_URL=https://your-app.railway.app

# Optional: skip Twilio signature validation in dev
SKIP_TWILIO_VALIDATION=false

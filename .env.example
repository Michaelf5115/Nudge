# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...             # public key (kept for reference)
SUPABASE_SERVICE_ROLE_KEY=eyJ...     # server-side only — NEVER expose this in client code

# Resend (email magic links)
RESEND_API_KEY=re_...

# App
PORT=3000
BASE_URL=https://your-app.railway.app

# Optional: override webhook validation in dev (set to "true" to skip Twilio sig check)
SKIP_TWILIO_VALIDATION=false
